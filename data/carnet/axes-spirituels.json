    "lien":     { "label": "Le lien",     "sens": "Le lien révèle l'ego. Il montre là où le cœur s'ouvre, se défend, se ferme ou revient." },
    "corps":    { "label": "Le corps et l'état", "sens": "Le corps signale souvent le mouvement de la nafs avant que la pensée ne le justifie." },
    "pratique": { "label": "La pratique spirituelle", "sens": "La pratique ne doit pas rester séparée de la journée. Elle descend dans la parole, le geste, la patience et la réparation." }
