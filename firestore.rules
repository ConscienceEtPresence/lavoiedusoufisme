// ============================================================
// Firestore Rules — La voie du dedans / Le carnet du dedans
// Version 1 — à coller dans Firebase Console → Firestore → Rules
// ============================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'ennealyon@gmail.com';
    }

    function isValidPrenom(s) {
      return s is string && s.size() > 0 && s.size() < 100;
    }
    function isValidContact(s) {
      return s is string && s.size() > 0 && s.size() < 200;
    }
    function isValidMessage(s) {
      return s == null || (s is string && s.size() < 2000);
    }

    // — codes : les clés des utilisateurs —
    // Lecture : permise pour la connexion (filtrage par prenomNorm + motGraine
    // côté client). L'admin liste tout. Les autres ne peuvent obtenir un
    // document que via get() avec son ID exact.
    match /codes/{codeId} {
      allow get:    if true;       // get(codeId) : pour login + revérification
      allow list:   if true;       // query nécessaire pour le login
      allow create, update, delete: if isAdmin();
    }

    // — demandes : création publique avec validation —
    match /demandes/{ticketId} {
      allow create: if
        isValidPrenom(request.resource.data.prenom) &&
        isValidContact(request.resource.data.contact) &&
        isValidMessage(request.resource.data.message) &&
        request.resource.data.statut == 'en-attente' &&
        request.resource.data.langue in ['fr','en'];
      allow read, update, delete: if isAdmin();
    }

    // — suggestions : création publique avec validation —
    match /suggestions/{id} {
      allow create: if
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() < 2000 &&
        request.resource.data.statut == 'neuve' &&
        request.resource.data.langue in ['fr','en'];
      allow read, update, delete: if isAdmin();
    }

    // — carnets : chacun son sous-arbre par codeId —
    // Les codeId sont des IDs Firestore auto-générés (20+ chars aléatoires)
    // Sans Firebase Anonymous Auth, on ne peut pas lier l'accès au mot-graine
    // côté serveur ; on accepte donc l'accès si on connaît le codeId.
    // V2 : ajouter Firebase Anonymous Auth + custom claims via Cloud Function.
    match /carnets/{codeId}/{document=**} {
      allow read, write: if true;
    }

    // — tout le reste interdit —
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
