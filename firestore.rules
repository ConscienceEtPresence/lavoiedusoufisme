// ============================================================
// Firestore Rules — La voie du dedans / Le carnet du dedans
//                  + Le miroir intérieur (ennéagramme)
// Version 2 — à coller dans Firebase Console → Firestore → Rules
// ============================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'ennealyon@gmail.com';
    }

    function isValidPrenom(s) {
      return s is string && s.size() > 0 && s.size() < 100;
    }
    function isValidContact(s) {
      return s is string && s.size() > 0 && s.size() < 200;
    }
    function isValidMessage(s) {
      return s == null || (s is string && s.size() < 2000);
    }
    function isValidType(n) {
      return n is int && n >= 1 && n <= 9;
    }

    // ============================================================
    // === LA VOIE DU DEDANS (carnet soufi par mot-graine) ===
    // ============================================================

    // — codes : les clés des utilisateurs —
    match /codes/{codeId} {
      allow get:    if true;
      allow list:   if true;
      allow create, update, delete: if isAdmin();
    }

    // — demandes : création publique avec validation —
    match /demandes/{ticketId} {
      allow create: if
        isValidPrenom(request.resource.data.prenom) &&
        isValidContact(request.resource.data.contact) &&
        isValidMessage(request.resource.data.message) &&
        request.resource.data.statut == 'en-attente' &&
        request.resource.data.langue in ['fr','en'];
      allow read, update, delete: if isAdmin();
    }

    // — suggestions : création publique avec validation —
    match /suggestions/{id} {
      allow create: if
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() < 2000 &&
        request.resource.data.statut == 'neuve' &&
        request.resource.data.langue in ['fr','en'];
      allow read, update, delete: if isAdmin();
    }

    // — carnets : chacun son sous-arbre par codeId —
    match /carnets/{codeId}/{document=**} {
      allow read, write: if true;
    }

    // ============================================================
    // === LE MIROIR INTÉRIEUR (carnet ennéagramme par type) ===
    // ============================================================

    // — codes-type : les clés des utilisateurs du miroir intérieur —
    // Document : { prenom, prenomNorm, type (1-9), aile?, sousType?,
    //              langue, actif, creeLe, derniereVisite? }
    // Le 'code' qu'on donne aux gens = codeId Firestore auto-généré.
    match /codes-type/{codeId} {
      allow get:    if true;       // pour login + revérification de session
      allow list:   if true;       // pour login (query par prenomNorm)
      allow create, update, delete: if isAdmin();
    }

    // — demandes-type : demandes de clé pour le miroir intérieur —
    // Document : { prenom, contact, typeDeclare (1-9), commentIdentifie,
    //              message?, statut, langue, creeLe }
    match /demandes-type/{ticketId} {
      allow create: if
        isValidPrenom(request.resource.data.prenom) &&
        isValidContact(request.resource.data.contact) &&
        isValidType(request.resource.data.typeDeclare) &&
        isValidMessage(request.resource.data.message) &&
        request.resource.data.statut == 'en-attente' &&
        request.resource.data.langue in ['fr','en'];
      allow read, update, delete: if isAdmin();
    }

    // — suggestions-type : retours sur le miroir intérieur —
    match /suggestions-type/{id} {
      allow create: if
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() < 2000 &&
        request.resource.data.statut == 'neuve' &&
        request.resource.data.langue in ['fr','en'];
      allow read, update, delete: if isAdmin();
    }

    // — carnets-type : sous-arbre journalier par codeId du miroir —
    // Structure : carnets-type/{codeId}/jours/{YYYY-MM-DD}
    // Le document du jour contient : niveau, ego, essence, moment,
    //   poser, reprise — selon ce que l'utilisateur a rempli.
    match /carnets-type/{codeId}/{document=**} {
      allow read, write: if true;
    }

    // — tout le reste interdit —
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
